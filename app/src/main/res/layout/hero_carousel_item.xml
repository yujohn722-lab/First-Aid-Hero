<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/carouselCard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="4dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/carouselImage"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/hero_mascot" />

        <TextView
            android:id="@+id/carouselTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="YOU DON'T NEED POWERS\nTO BE A HERO"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/carouselText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Be the help they need.\nLearn to handle cuts, burns, and more!"
            android:textAlignment="center"
            android:textColor="#49454F"
            android:textSize="14sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>